<Window x:Class="SayraDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SayraDashboard"
        xmlns:vm="clr-namespace:SayraDashboard.ViewModels"
        mc:Ignorable="d"
        Title="SAYRA Dashboard" Height="800" Width="1400"
        Background="{StaticResource BgBrush}"
        FlowDirection="RightToLeft">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Navigation -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource SecondaryBrush}" Padding="32,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="SAYRA" Style="{StaticResource HeaderLogoStyle}" />
                    <Rectangle Width="2" Height="32" Fill="{StaticResource BorderBrush}" Margin="32,0" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PcName}" Style="{StaticResource PcNameStyle}" />
                        <Border Background="{StaticResource Primary50Brush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" CornerRadius="16" Padding="12,4">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Connected" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,32,0">
                        <TextBlock Text="{Binding CurrentTime}" Style="{StaticResource TimeStyle}" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding CurrentDate}" Style="{StaticResource DateStyle}" HorizontalAlignment="Right" />
                    </StackPanel>
                    <Button Command="{Binding ShutdownCommand}" Style="{StaticResource PowerButtonStyle}">
                        <Path Data="M12,2V12M12,2A10,10 0 1,1 2,12A10,10 0 0,1 12,2" Stroke="{StaticResource RedBrush}" StrokeThickness="3" Width="24" Height="24" Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" BorderThickness="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">
                <!-- Hero Section -->
                <Border Height="320" CornerRadius="24" Margin="0,0,0,40">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1B1B20" Offset="0" />
                            <GradientStop Color="#111115" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <!-- Background Pattern/Text -->
                        <TextBlock Text="SAYRA" FontSize="180" FontWeight="Black" Foreground="White" Opacity="0.03" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,40" />

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TimerValue}" Style="{StaticResource TimerTextStyle}" HorizontalAlignment="Center" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                                <Border Style="{StaticResource GlassCardStyle}" Margin="0,0,16,0">
                                    <StackPanel>
                                        <TextBlock Text="هزینه جلسه" Foreground="{StaticResource White2Brush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding PhoneCost}" Foreground="{StaticResource PrimaryBrush}" FontSize="20" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="موجودی" Foreground="{StaticResource White2Brush}" FontSize="12" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding WalletBalance}" Foreground="{StaticResource WhiteBrush}" FontSize="20" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Section Header & Search -->
                <Grid Margin="0,0,0,24">
                    <TextBlock Text="بازی‌های نصب شده" Style="{StaticResource TitleStyle}" VerticalAlignment="Center" />
                    <TextBox Text="{Binding SearchQuery}" Width="320" Height="48" Style="{StaticResource SearchBoxStyle}" HorizontalAlignment="Right" />
                </Grid>

                <!-- Game Grid -->
                <ListBox ItemsSource="{Binding GameItems}" Style="{StaticResource GameListBoxStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="240" Height="320" Style="{StaticResource GameCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Game Cover Image -->
                                    <Border x:Name="ImageContainer" Grid.Row="0" CornerRadius="20,20,0,0" ClipToBounds="True">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                        </Border.Background>
                                        <Border x:Name="Placeholder" Background="#2A2A30" Visibility="Collapsed">
                                            <TextBlock Text="?" Foreground="{StaticResource White2Brush}" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.1" />
                                        </Border>
                                    </Border>

                                    <Border Grid.Row="1" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Category}" Foreground="{StaticResource White2Brush}" FontSize="13" Margin="0,4,0,16" />
                                            <Button Content="{Binding ButtonText}" Style="{StaticResource PlayButtonStyle}"
                                                    Command="{Binding DataContext.PlayGameCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding ImageUrl}" Value="{x:Null}">
                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ImageUrl}" Value="">
                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Right Sidebar (System Info) -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Padding="32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="مشخصات سیستم" Style="{StaticResource SidebarHeaderStyle}" />

                    <Border Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="CPU" Foreground="{StaticResource White2Brush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBlock Text="Intel Core i7-13500F" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="GPU" Foreground="{StaticResource White2Brush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBlock Text="NVIDIA RTX 4090" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="RAM" Foreground="{StaticResource White2Brush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBlock Text="32GB DDR5 6000MHz" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Display" Foreground="{StaticResource White2Brush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBlock Text="4K OLED 144Hz" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Button Grid.Row="1" Content="پایان دادن به استفاده" Height="56" Style="{StaticResource EndSessionButtonStyle}" Command="{Binding EndSessionCommand}" />
            </Grid>
        </Border>
    </Grid>
</Window>
