<Window x:Class="SayraDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SayraDashboard"
        xmlns:vm="clr-namespace:SayraDashboard.ViewModels"
        mc:Ignorable="d"
        Title="SAYRA Dashboard" Height="720" Width="1280"
        Background="{StaticResource BgBrush}"
        FlowDirection="RightToLeft">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid x:Name="Header" Grid.Row="0" Grid.ColumnSpan="2" Margin="24,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock x:Name="Logo" Text="SAYRA" Style="{StaticResource HeaderLogoStyle}" />
                <StackPanel x:Name="PcStatus" Orientation="Horizontal" Margin="40,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="PcName" Text="{Binding PcName}" Style="{StaticResource PcNameStyle}" />
                    <Border x:Name="StatusBadge" Background="{StaticResource Primary50Brush}" BorderBrush="{StaticResource Primary2Brush}" BorderThickness="1" CornerRadius="20" Padding="12,4">
                        <TextBlock Text="Connected" Foreground="{StaticResource Primary2Brush}" FontSize="12" />
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="DateTime" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,60,0">
                <TextBlock x:Name="Time" Text="{Binding CurrentTime}" Style="{StaticResource TimeStyle}" HorizontalAlignment="Right" />
                <TextBlock x:Name="Date" Text="{Binding CurrentDate}" Style="{StaticResource DateStyle}" HorizontalAlignment="Right" />
            </StackPanel>

            <Button x:Name="PowerBtn" Command="{Binding ShutdownCommand}" Style="{StaticResource PowerButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Path Data="M12,2V12M12,2A10,10 0 1,1 2,12A10,10 0 0,1 12,2" Stroke="{StaticResource RedBrush}" StrokeThickness="2" />
            </Button>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer x:Name="MainContent" Grid.Row="1" Grid.Column="0" Padding="24" Background="{StaticResource BgBrush}" BorderThickness="0">
            <StackPanel>
                <!-- Hero Timer -->
                <Grid x:Name="HeroTimer" Height="200" Margin="0,0,0,30">
                    <TextBlock Text="SAYRA" FontSize="150" Foreground="{StaticResource WhiteBrush}" Opacity="0.05" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="TimerText" Text="{Binding TimerValue}" FontFamily="{StaticResource TimerFont}" FontSize="70" Foreground="{StaticResource WhiteBrush}" HorizontalAlignment="Center" />

                        <StackPanel x:Name="InfoCards" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Border x:Name="CostCard" Background="{StaticResource SecondaryBrush}" CornerRadius="16" Height="53" Padding="16,0" Margin="0,0,20,0">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Placeholder for Money Icon -->
                                    <Ellipse Width="24" Height="24" Fill="{StaticResource PrimaryBrush}" Margin="0,0,10,0" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="هزینه تلفن" Foreground="{StaticResource White2Brush}" FontSize="10" />
                                        <TextBlock Text="{Binding PhoneCost}" Foreground="{StaticResource WhiteBrush}" FontSize="14" FontWeight="SemiBold" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border x:Name="WalletCard" Background="{StaticResource SecondaryBrush}" CornerRadius="16" Height="53" Padding="16,0">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Placeholder for Wallet Icon -->
                                    <Ellipse Width="24" Height="24" Fill="{StaticResource PrimaryBrush}" Margin="0,0,10,0" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="موجودی کیف" Foreground="{StaticResource White2Brush}" FontSize="10" />
                                        <TextBlock Text="{Binding WalletBalance}" Foreground="{StaticResource WhiteBrush}" FontSize="14" FontWeight="SemiBold" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Search Area -->
                <Grid x:Name="SearchArea" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Text="{Binding SearchQuery}" Width="400" Height="40" Style="{StaticResource SearchBoxStyle}" HorizontalAlignment="Left" />
                    <TextBlock x:Name="GameSectionTitle" Grid.Column="1" Text="بخش بازی ها" Style="{StaticResource TitleStyle}" VerticalAlignment="Center" />
                </Grid>

                <!-- Games Grid -->
                <ItemsControl x:Name="GamesGrid" ItemsSource="{Binding GameItems}" Width="1045" HorizontalAlignment="Left">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="240" Height="276" CornerRadius="20" Margin="0,0,20,20">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ImageUrl}" Stretch="UniformToFill" />
                                </Border.Background>
                                <Grid>
                                    <Border CornerRadius="20" Background="{StaticResource Dark50Brush}" VerticalAlignment="Stretch" />
                                    <StackPanel VerticalAlignment="Bottom" Margin="18">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource GameNameStyle}" />
                                        <TextBlock Text="{Binding Category}" Style="{StaticResource GameCategoryStyle}" Margin="0,4,0,12" />
                                        <Button x:Name="GameActionBtn" Content="{Binding ButtonText}" Height="31" Style="{StaticResource PlayButtonStyle}"
                                                Command="{Binding DataContext.PlayGameCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Sidebar -->
        <Border x:Name="Sidebar" Grid.Row="1" Grid.Column="1" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel x:Name="SystemInfoList" Grid.Row="0">
                    <TextBlock Text="System Detail" Style="{StaticResource SidebarHeaderStyle}" Margin="0,0,0,15" />
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,15" />

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="20" Height="20" Fill="{StaticResource White2Brush}" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="i7 13500f" Foreground="{StaticResource WhiteBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,15" />

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="20" Height="20" Fill="{StaticResource White2Brush}" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="RTX 4090" Foreground="{StaticResource WhiteBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,15" />

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="20" Height="20" Fill="{StaticResource White2Brush}" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="32GB" Foreground="{StaticResource WhiteBrush}" VerticalAlignment="Center" />
                    </Grid>
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,15" />

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="20" Height="20" Fill="{StaticResource White2Brush}" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="4k Oled" Foreground="{StaticResource WhiteBrush}" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>

                <Button x:Name="EndSessionBtn" Grid.Row="1" Content="پایان دادن به استفاده" Height="50" Style="{StaticResource EndSessionButtonStyle}" Command="{Binding EndSessionCommand}" />
            </Grid>
        </Border>
    </Grid>
</Window>
