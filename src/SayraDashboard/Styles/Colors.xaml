<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorBg">#101014</Color>
    <Color x:Key="ColorPrimary">#f4f46b</Color>
    <Color x:Key="ColorPrimary2">#ffff3d</Color>
    <Color x:Key="ColorWhite">#ffffff</Color>
    <Color x:Key="ColorWhite2">#9A9A9A</Color>
    <Color x:Key="ColorSecondary">#1F1F23</Color>
    <Color x:Key="ColorBorder">#252528</Color>
    <Color x:Key="ColorPrimary50">#2cf4f46b</Color> <!-- Fixed ARGB format -->
    <Color x:Key="ColorDark50">#8a101014</Color> <!-- Fixed ARGB format -->
    <Color x:Key="ColorRed">#F46B6B</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource ColorBg}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="Primary2Brush" Color="{StaticResource ColorPrimary2}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource ColorWhite}" />
    <SolidColorBrush x:Key="White2Brush" Color="{StaticResource ColorWhite2}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource ColorSecondary}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="Primary50Brush" Color="{StaticResource ColorPrimary50}" />
    <SolidColorBrush x:Key="Dark50Brush" Color="{StaticResource ColorDark50}" />
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource ColorRed}" />

    <FontFamily x:Key="MainFont">Segoe UI, peyda, sans-serif</FontFamily>
    <FontFamily x:Key="TimerFont">Black Ops One</FontFamily>
</ResourceDictionary>
